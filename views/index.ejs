<head>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <link rel="icon" type="image/png" href="/assets/paw-svgrepo-com.svg">
    <title>Grooming Orders</title>
</head>
<main>
    <div>
        <img src="/assets/paw-svgrepo-com.svg" alt="">
        <h1>
            <%=title%>
        </h1>
    </div>
    <div class="grooming-requests-wrapper">
        <% groomingOrders.forEach((groomingOrder, index)=> { %>
            <div class="grooming-request">
                <div>
                    <h3>
                        <%= groomingOrder.dog %> - Grooming Order
                    </h3>
                    <span class="grooming-request-timestamp">
                        <%= groomingOrder.added %>
                    </span>
                </div>
                <div class="grooming-order-buttons">
                    <a href="/grooming-requests/<%= groomingOrder.id%>" class="view-grooming-request">View
                        Request</a>
                    <form method="POST" action="/grooming-requests/delete/<%=groomingOrder.id%>">
                        <button class="delete-grooming-request" type="submit">Delete</button>
                    </form>
                </div>
            </div>
            <% }) %>
                <a href="/grooming-requests/new" class="new-grooming-request">New Grooming Order</a>
    </div>
</main>
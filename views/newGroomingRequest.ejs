<head>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <link rel="icon" type="image/png" href="/assets/paw-svgrepo-com.svg">
    <title>New Grooming Request</title>
</head>
<main>
    <a href="/" class="back-button"><img src="/assets/back-svgrepo-com.svg" alt=""> Back</a>
    <div>
        <img src="/assets/paw-svgrepo-com.svg" alt="">
        <h1>
            <%=title%>
        </h1>
    </div>
    <form method="POST" action="/grooming-requests/new" class="new-grooming-request-container">
        <label>
            Name of Canine*: <input type="text" name="dog_name" required placeholder="Ex: Niloo">
        </label>
        <label>
            Grooming Request(s)*: <textarea type="text" name="grooming_requests"
                placeholder="Ex: Bath and nail trim"></textarea>
        </label>
        <button type="submit">Submit</button>
        <%- include("partials/errors.ejs") %>

    </form>
</main>